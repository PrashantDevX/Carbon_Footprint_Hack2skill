# -----------------------------------------
# FIREBASE CONFIG (from Firebase Console)
# -----------------------------------------
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------
# FIREBASE APP CHECK (reCAPTCHA v3)
# -----------------------------------------
VITE_RECAPTCHA_SITE_KEY=6LcXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------
# GOOGLE AI / GEMINI
# -----------------------------------------
VITE_GEMINI_API_KEY=AIzaSy...
# Optional: override the model (defaults to gemini-3.1-flash-lite with fallbacks)
VITE_GEMINI_MODEL=gemini-3.1-flash-lite

# -----------------------------------------
# GOOGLE MAPS (enables the live Green Map with nearby places)
# Requires Maps JavaScript API + Places API enabled on the key.
# Without it, the Green Map shows a styled demo fallback.
# -----------------------------------------
VITE_GOOGLE_MAPS_API_KEY=AIzaSy...
VITE_GOOGLE_MAPS_MAP_ID=your-map-id

# -----------------------------------------
# FIREBASE CLOUD MESSAGING (VAPID)
# -----------------------------------------
VITE_FIREBASE_VAPID_KEY=BPxxxxxx...

# -----------------------------------------
# APP CONFIG
# -----------------------------------------
VITE_APP_NAME=EcoTrack
VITE_APP_URL=https://your-project.web.app
